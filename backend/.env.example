# HearTech backend environment variables
# Copy to backend/.env and fill in real values. Never commit backend/.env.

# Referral AI (backend/services/referral_ai_service.py)
GEMINI_API_KEY=
REFERRAL_USE_LOCAL_MODEL=false

# OneSignal push notifications (backend/services/notification_service.py)
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# Cloudinary signed uploads (backend/routers/utils.py — cloudinary-signature endpoint)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Flutter client (--dart-define at build/run time)
# flutter run --dart-define=CLOUDINARY_CLOUD_NAME=... --dart-define=CLOUDINARY_API_KEY=... --dart-define=ONESIGNAL_APP_ID=...
