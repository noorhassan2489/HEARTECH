rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isHCW() {
      return isSignedIn() && getUserRole() == 'hcw';
    }

    function isParent() {
      return isSignedIn() && getUserRole() == 'parent';
    }

    function isTeacher() {
      return isSignedIn() && getUserRole() == 'teacher';
    }

    // ═══════════════════════════════════════════════════════════════════════
    // USERS — /users/{uid}
    // ═══════════════════════════════════════════════════════════════════════

    match /users/{uid} {
      // Users can read their own profile; HCWs/teachers can read other profiles
      // (needed for child profile screens showing parent/HCW info)
      allow read: if isSignedIn();
      // Users can create/update their own profile
      allow create, update: if isOwner(uid);
      // No deletes
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CHILDREN — /children/{childId}
    // ═══════════════════════════════════════════════════════════════════════

    match /children/{childId} {
      // HCW can read children they created or are attached to
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.hcwIds ||
        resource.data.parentId == request.auth.uid ||
        request.auth.uid in resource.data.get('teacherIds', [])
      );

      // Only HCW can create children
      allow create: if isHCW();

      // HCW, Parent, and Teacher can update (with field restrictions)
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.hcwIds ||
        resource.data.parentId == request.auth.uid ||
        request.auth.uid in resource.data.get('teacherIds', [])
      );

      allow delete: if false;

      // ── Screenings subcollection ──────────────────────────────────────
      match /screenings/{screeningId} {
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.hcwIds ||
          get(/databases/$(database)/documents/children/$(childId)).data.parentId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.get('teacherIds', [])
        );
        allow create: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.hcwIds ||
          get(/databases/$(database)/documents/children/$(childId)).data.parentId == request.auth.uid
        );
        allow update, delete: if false;
      }

      // ── Teacher Observations subcollection ────────────────────────────
      match /teacherObservations/{obsId} {
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.hcwIds ||
          get(/databases/$(database)/documents/children/$(childId)).data.parentId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.get('teacherIds', [])
        );
        allow create: if isTeacher() &&
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.get('teacherIds', []);
        allow update, delete: if false;
      }

      // ── Referrals subcollection ───────────────────────────────────────
      match /referrals/{referralId} {
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.hcwIds ||
          get(/databases/$(database)/documents/children/$(childId)).data.parentId == request.auth.uid
        );
        allow create: if isHCW();
        allow update, delete: if false;
      }

      // ── Speech Logs subcollection ─────────────────────────────────────
      match /speechLogs/{logId} {
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.hcwIds ||
          get(/databases/$(database)/documents/children/$(childId)).data.parentId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.get('teacherIds', [])
        );
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/children/$(childId)).data.parentId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.get('teacherIds', [])
        );
        allow update, delete: if false;
      }

      // ── Notes subcollection ───────────────────────────────────────────
      match /notes/{noteId} {
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.hcwIds ||
          get(/databases/$(database)/documents/children/$(childId)).data.parentId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.get('teacherIds', [])
        );
        allow create: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.hcwIds
        );
        allow update: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/children/$(childId)).data.hcwIds
        );
        allow delete: if false;
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // HCW ANONYMOUS SCREENINGS — /hcw_screenings/{screeningId}
    // ═══════════════════════════════════════════════════════════════════════

    match /hcw_screenings/{screeningId} {
      allow read: if isHCW() && resource.data.hcwId == request.auth.uid;
      allow create: if isHCW();
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // INVITES — /invites/{inviteId}
    // ═══════════════════════════════════════════════════════════════════════

    match /invites/{inviteId} {
      // Parent who created or teacher who received can read
      allow read: if isSignedIn() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.teacherUid == request.auth.uid ||
        resource.data.teacherEmail == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email
      );
      allow create: if isParent();
      allow update: if isSignedIn(); // Teacher accepts/declines
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS — /notifications/{uid}/items/{notifId}
    // ═══════════════════════════════════════════════════════════════════════

    match /notifications/{uid}/items/{notifId} {
      allow read: if isOwner(uid);
      allow create: if true; // Backend (admin SDK) creates these
      allow update: if isOwner(uid); // User marks as read
      allow delete: if isOwner(uid); // User deletes
    }
  }
}
