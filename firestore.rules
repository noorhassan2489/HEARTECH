rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isHCW() {
      return isSignedIn() && getUserRole() == 'hcw';
    }

    function isParent() {
      return isSignedIn() && getUserRole() == 'parent';
    }

    function isTeacher() {
      return isSignedIn() && getUserRole() == 'teacher';
    }

    function childData(childId) {
      return get(/databases/$(database)/documents/children/$(childId)).data;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // USERS — /users/{uid}
    // ═══════════════════════════════════════════════════════════════════════

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CHILDREN — /children/{childId}
    // ═══════════════════════════════════════════════════════════════════════

    match /children/{childId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.hcwIds ||
        resource.data.parentId == request.auth.uid ||
        request.auth.uid in resource.data.get('teacherIds', [])
      );

      allow create: if isHCW();

      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.hcwIds ||
        resource.data.parentId == request.auth.uid ||
        request.auth.uid in resource.data.get('teacherIds', [])
      );

      allow delete: if false;

      // ── Screenings subcollection ──────────────────────────────────────
      match /screenings/{screeningId} {
        allow read: if isSignedIn() && (
          request.auth.uid in childData(childId).hcwIds ||
          childData(childId).parentId == request.auth.uid ||
          request.auth.uid in childData(childId).get('teacherIds', [])
        );
        allow create: if isSignedIn() && (
          request.auth.uid in childData(childId).hcwIds ||
          childData(childId).parentId == request.auth.uid
        );
        allow update, delete: if false;
      }

      // ── Teacher Observations subcollection ────────────────────────────
      match /teacherObservations/{obsId} {
        allow read: if isSignedIn() && (
          (
            isTeacher() &&
            resource.data.teacherUid == request.auth.uid &&
            request.auth.uid in childData(childId).get('teacherIds', [])
          ) ||
          (
            isParent() &&
            childData(childId).parentId == request.auth.uid
          ) ||
          (
            isHCW() &&
            resource.data.isVisibleToHcw == true &&
            request.auth.uid in resource.data.get('visibleToHcwIds', [])
          )
        );
        allow create: if isTeacher() &&
          request.auth.uid in childData(childId).get('teacherIds', []);
        allow update: if isParent() &&
          childData(childId).parentId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isVisibleToHcw', 'visibleToHcwIds']);
        allow delete: if false;
      }

      // ── Referrals subcollection ───────────────────────────────────────
      match /referrals/{referralId} {
        allow read: if isSignedIn() && (
          request.auth.uid in childData(childId).hcwIds ||
          (
            resource.data.get('parentId', '') == request.auth.uid &&
            resource.data.get('isVisibleToParent', false) == true
          ) ||
          request.auth.uid in resource.data.get('visibleToTeacherIds', [])
        );
        allow create: if isHCW() &&
          request.auth.uid in childData(childId).hcwIds;
        allow update: if isSignedIn() && (
          request.auth.uid in childData(childId).hcwIds ||
          (
            isParent() &&
            resource.data.get('parentId', '') == request.auth.uid &&
            resource.data.get('isVisibleToParent', false) == true &&
            resource.data.get('status', '') == 'finalized' &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['isVisibleToTeacher', 'visibleToTeacherIds'])
          )
        );
        allow delete: if false;
      }

      // ── Speech Logs subcollection ─────────────────────────────────────
      match /speechLogs/{logId} {
        allow read: if isSignedIn() && (
          request.auth.uid in childData(childId).hcwIds ||
          childData(childId).parentId == request.auth.uid ||
          (
            request.auth.uid in childData(childId).get('teacherIds', []) &&
            resource.data.conductedBy == request.auth.uid
          )
        );
        allow create: if isSignedIn() && (
          childData(childId).parentId == request.auth.uid ||
          request.auth.uid in childData(childId).get('teacherIds', [])
        );
        allow update, delete: if false;
      }

      // ── Notes subcollection ───────────────────────────────────────────
      match /notes/{noteId} {
        allow read: if isSignedIn() && (
          (
            isHCW() &&
            request.auth.uid in childData(childId).hcwIds &&
            (
              resource.data.authorRole == 'hcw' ||
              (
                resource.data.authorRole == 'teacher' &&
                resource.data.isVisibleToHcw == true &&
                request.auth.uid in resource.data.get('visibleToHcwIds', [])
              )
            )
          ) ||
          (
            isParent() &&
            resource.data.parentId == request.auth.uid &&
            resource.data.isPublic == true
          ) ||
          (
            isTeacher() &&
            request.auth.uid in resource.data.get('visibleToTeacherIds', []) &&
            resource.data.isTeacherVisible == true
          )
        );
        allow create: if isSignedIn() && (
          (
            isHCW() &&
            request.auth.uid in childData(childId).hcwIds
          ) ||
          (
            isTeacher() &&
            request.auth.uid in childData(childId).get('teacherIds', []) &&
            request.resource.data.authorRole == 'teacher' &&
            request.resource.data.isPublic == true
          )
        );
        allow update: if isSignedIn() && (
          (
            isHCW() &&
            request.auth.uid in childData(childId).hcwIds &&
            resource.data.authorRole == 'hcw'
          ) ||
          (
            isParent() &&
            childData(childId).parentId == request.auth.uid &&
            resource.data.authorRole == 'teacher' &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['isVisibleToHcw', 'visibleToHcwIds'])
          )
        );
        allow delete: if false;
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // HCW ANONYMOUS SCREENINGS — /hcw_screenings/{screeningId}
    // ═══════════════════════════════════════════════════════════════════════

    match /hcw_screenings/{screeningId} {
      allow read: if isHCW() && resource.data.hcwId == request.auth.uid;
      allow create: if isHCW();
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // INVITES — /invites/{inviteId}
    // ═══════════════════════════════════════════════════════════════════════

    match /invites/{inviteId} {
      allow read: if isSignedIn() && (
        resource.data.parentUid == request.auth.uid ||
        resource.data.get('parentId', '') == request.auth.uid ||
        resource.data.teacherUid == request.auth.uid ||
        resource.data.hcwUid == request.auth.uid ||
        resource.data.teacherEmail == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email ||
        resource.data.get('hcwEmail', '') == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email
      );
      allow create: if isParent();
      allow update: if isSignedIn() && (
        (
          resource.data.parentUid == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          request.resource.data.status == 'cancelled'
        ) ||
        (
          resource.data.teacherUid == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
          request.resource.data.status in ['accepted', 'declined']
        )
      );
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS — /notifications/{uid}/items/{notifId}
    // ═══════════════════════════════════════════════════════════════════════

    match /notifications/{uid}/items/{notifId} {
      allow read: if isOwner(uid);
      // Writes are backend-only (Admin SDK bypasses rules). Clients must not create notifications.
      allow create: if false;
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }
  }
}
