rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    
    function getRole() {
      // Assuming role is stored in custom claims, or we fetch from /users/uid
      // If custom claim (recommended): return request.auth.token.role;
      // If reading from doc (costs 1 read): return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      // For simplicity in this mock, we assume the frontend enforces it or we rely on the `users` collection.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // 1. Users Collection
    match /users/{uid} {
      // Anyone can create their own profile during registration
      allow create: if isOwner(uid);
      // Users can read/update their own profile
      allow read, update: if isOwner(uid);
      // HCWs can read Parent profiles for linking (requires a query, so allow read if auth)
      allow read: if isAuth(); // Looser rule for directory / linking features
      allow delete: if false; // No deletion from app directly
    }

    // 2. Children Collection
    match /children/{childId} {
      // Anyone authenticated can theoretically create a child (HCW creates, Parent claims)
      allow create: if isAuth();
      
      // Read/Update rules based on relationship
      allow read, update: if isAuth() && (
        // HCW array contains user
        request.auth.uid in resource.data.hcwIds ||
        // Parent array contains user
        request.auth.uid in resource.data.parentIds ||
        // Teacher array contains user
        request.auth.uid in resource.data.teacherIds
      );
    }

    // 3. Screenings / Questionnaires
    match /screenings/{screeningId} {
      allow create: if isAuth();
      // Only linked users to the child can read the screening
      // This requires the screening doc to have `hcwId`, `parentId`, or we fetch the child.
      allow read: if isAuth(); // Simplified for MVP. Ideally restrict by child's linked IDs.
    }

    // 4. Notifications
    match /notifications/{uid}/items/{notificationId} {
      // Only the specific user can read/update their notifications
      allow read, update: if isOwner(uid);
      // System/Backend (admin SDK) will create these, flutter app shouldn't create them directly
      allow create: if isOwner(uid); 
      allow delete: if isOwner(uid);
    }

    // 5. Invites
    match /invites/{inviteId} {
      // Authenticated users can create invites
      allow create: if isAuth();
      // Read/update if you are the sender or receiver
      allow read, update: if isAuth() && (
        request.auth.uid == resource.data.senderId ||
        request.auth.uid == resource.data.receiverId ||
        request.auth.token.email == resource.data.receiverEmail
      );
    }
  }
}
